# RAE Hive Reporting Configuration
# Rename this file to .env on Node 1 in ~/RAE-Suite/packages/rae-hive/

# Your Gmail address
REPORT_EMAIL_USER=your-email@gmail.com

# Your Gmail App Password (NOT your regular password!)
# Generate it here: https://myaccount.google.com/apppasswords
REPORT_EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Where to send the reports
REPORT_EMAIL_RECIPIENT=your-destination@email.com
